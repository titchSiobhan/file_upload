<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>folder</title>
    <link rel="stylesheet" href="/styles.css">
    <script src="https://kit.fontawesome.com/9e80d3d242.js" crossorigin="anonymous"></script>
</head>
<body>
      <h1>Upload Dashboard</h1>
    
        <% if (locals.user) { %>

<%- include('nav', {links: links}) %>

        <% } %>
    
    
   <h2><%= folder.folderName %></h2>
   <div class="fileArea">
    <% if (file) { %>
    <%- include ('file', {file}) %>
    <% } else { %> 
        <p>No file</p>
        <% } %>
        </div>
    
</body>
</html>